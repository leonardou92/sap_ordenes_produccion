# Copiar: cp .env.example .env
#
# Variables usadas por el código (src/config.ts + Prisma CLI).
# Sync y GET /ordenes por rango van siempre a Sybase (fetchOrdenesProduccionByRango);
# no se usan SAP_SOURCE_MODE, RFC ni REST salvo que amplíes SapService.fetchData().

# ─────────────────────────────────────────────────────────────────────────────
# App + API
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
PORT=3001
API_BASE_PATH=/ordenes-produccion
# API: interfaz de escucha (127.0.0.1 si solo aceptas tráfico del proxy en el mismo host)
LISTEN_HOST=0.0.0.0
# Tras proxy inverso: 1 o true (X-Forwarded-For). Sin proxy: false
TRUST_PROXY=1
# GET .../api/ordenes-produccion?desde=&hasta= (consulta SAP). false = ruta no expuesta; health sigue activo.
ENABLE_ORDENES_CONSULTA_API=false

# ─────────────────────────────────────────────────────────────────────────────
# Sync → SQL Server
# ─────────────────────────────────────────────────────────────────────────────
SYNC_TABLE=ordenes_produccion
# Texto en sync_logs.targetTable para el job de órdenes (por defecto = SYNC_TABLE)
SYNC_LOG_TARGET_TABLE=OP_ordenes_produccion
SYNC_BATCH_SIZE=500
SYNC_CONFLICT_KEYS=sap_line_id
# Fecha global de inicio (la usan ambos cronjobs: órdenes y logística)
SYNC_FECHA_INICIO=2025-01-01
SYNC_WERKS=

# Lote y flag compartidos: FACT/DIM (incluye dim_plantas) y los 4 reportes diario PB
# (fact_produccion_resumen, fact_recepcion_camiones, fact_produccion_detalle_reporte, fact_materiales_empaque).
# Fecha mínima GSTRI/ERDAT en SAP: SYNC_FECHA_INICIO (YYYY-MM-DD → filtro YYYYMMDD en queries).
BATCH_SIZE=500
# Habilita/inhabilita esos jobs (false = no ejecutan aunque invoques el script)
ENABLE_SYNC=false

# ─────────────────────────────────────────────────────────────────────────────
# Sybase ASE (ODBC recomendado en Ubuntu: unixodbc + FreeTDS, DSN en /etc/odbc.ini)
# ─────────────────────────────────────────────────────────────────────────────
SYBASE_CONNECTION_MODE=odbc
SYBASE_DSN=SAP_ASE
SYBASE_DRIVER=FreeTDS
SYBASE_SERVER=
SYBASE_PORT=4901
SYBASE_DB=
SYBASE_UID=
SYBASE_PWD=

# Solo si SYBASE_CONNECTION_MODE=jdbc (Node 18 + jconn4.jar):
# SYBASE_JDBC_URL=jdbc:sybase:Tds:HOST:4901?ENCRYPT_PASSWORD=true
# SYBASE_JDBC_CLASS_NAME=com.sybase.jdbc4.jdbc.SybDriver
# SYBASE_JDBC_DRIVER_PATH=/opt/sap/jdbc/jconn4.jar
# JVM_PATH=/usr/lib/jvm/java-17-openjdk-amd64/lib/server

# ─────────────────────────────────────────────────────────────────────────────
# SQL Server (Knex)
# ─────────────────────────────────────────────────────────────────────────────
DB_CLIENT=mssql
DB_HOST=localhost
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_NAME=sap_sync
DB_SSL=false
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─────────────────────────────────────────────────────────────────────────────
# Prisma (npx prisma migrate deploy, generate)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="sqlserver://localhost:1433;database=sap_sync;user=USER;password=PASS;encrypt=false;trustServerCertificate=true"

# Migraciones en BD compartida: no prisma db push. Ver README.

# ─────────────────────────────────────────────────────────────────────────────
# Cron: scripts/sap-sync.cron.example (ajusta RUTA_REPO y TU_USUARIO)
# ─────────────────────────────────────────────────────────────────────────────
