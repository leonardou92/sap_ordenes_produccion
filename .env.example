# Copiar: cp .env.example .env
#
# Variables usadas por el código (src/config.ts + Prisma CLI).
# Sync y GET /ordenes por rango van siempre a Sybase (fetchOrdenesProduccionByRango);
# no se usan SAP_SOURCE_MODE, RFC ni REST salvo que amplíes SapService.fetchData().

# ─────────────────────────────────────────────────────────────────────────────
# App + API
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
PORT=3001
API_BASE_PATH=/ordenes-produccion

# ─────────────────────────────────────────────────────────────────────────────
# Sync → SQL Server
# ─────────────────────────────────────────────────────────────────────────────
SYNC_TABLE=ordenes_produccion
SYNC_BATCH_SIZE=500
SYNC_CONFLICT_KEYS=sap_line_id
SYNC_ERDAT_FROM=2025-01-01
SYNC_WERKS=

# ─────────────────────────────────────────────────────────────────────────────
# Sybase ASE (ODBC recomendado en Ubuntu: unixodbc + FreeTDS, DSN en /etc/odbc.ini)
# ─────────────────────────────────────────────────────────────────────────────
SYBASE_CONNECTION_MODE=odbc
SYBASE_DSN=SAP_ASE
SYBASE_DRIVER=FreeTDS
SYBASE_SERVER=
SYBASE_PORT=4901
SYBASE_DB=
SYBASE_UID=
SYBASE_PWD=

# Solo si SYBASE_CONNECTION_MODE=jdbc (Node 18 + jconn4.jar):
# SYBASE_JDBC_URL=jdbc:sybase:Tds:HOST:4901?ENCRYPT_PASSWORD=true
# SYBASE_JDBC_CLASS_NAME=com.sybase.jdbc4.jdbc.SybDriver
# SYBASE_JDBC_DRIVER_PATH=/opt/sap/jdbc/jconn4.jar
# JVM_PATH=/usr/lib/jvm/java-17-openjdk-amd64/lib/server

# ─────────────────────────────────────────────────────────────────────────────
# SQL Server (Knex)
# ─────────────────────────────────────────────────────────────────────────────
DB_CLIENT=mssql
DB_HOST=localhost
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_NAME=sap_sync
DB_SSL=false
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─────────────────────────────────────────────────────────────────────────────
# Prisma (npx prisma migrate deploy, generate)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="sqlserver://localhost:1433;database=sap_sync;user=USER;password=PASS;encrypt=false;trustServerCertificate=true"

# Migraciones en BD compartida: no prisma db push. Ver .env del servidor o README deploy.

# ─────────────────────────────────────────────────────────────────────────────
# Cron: deploy/sap-sync.cron.example (1×/día 16:37 America/Caracas)
# ─────────────────────────────────────────────────────────────────────────────
