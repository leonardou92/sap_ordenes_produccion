# Entorno servidor Ubuntu (SAP Sybase ASE + SQL Server destino)
# Copiar a .env: cp .env.example .env
# Instalacion ODBC: sudo apt install -y unixodbc unixodbc-dev freetds-bin freetds-common tdsodbc
# DSN ejemplo en /etc/odbc.ini: [SAP_ASE] Driver=FreeTDS Server=... Port=4901 TDS_Version=5.0
# Probar: isql -v SAP_ASE usuario password

NODE_ENV=production

LOG_LEVEL=info
PORT=3000

SYNC_TABLE=ordenes_produccion
SYNC_BATCH_SIZE=500
SYNC_CONFLICT_KEYS=id

SAP_SOURCE_MODE=sybase

SAP_APP_SERVER_HOST=
SAP_SYSTEM_NUMBER=00
SAP_CLIENT=100
SAP_USER=
SAP_PASSWORD=
SAP_LANG=ES

SAP_BASE_URL=
SAP_REST_ENDPOINT=/api/v1/materiales
SAP_API_KEY=
SAP_TIMEOUT_MS=30000

# Sybase ASE: en servidor Ubuntu usar ODBC + FreeTDS (ver odbcinst -q -d)
SYBASE_CONNECTION_MODE=odbc

SYBASE_DSN=SAP_ASE
SYBASE_DRIVER=FreeTDS
SYBASE_SERVER=
SYBASE_PORT=4901
SYBASE_DB=
SYBASE_UID=
SYBASE_PWD=

# JDBC opcional (jconn4.jar de SAP si ODBC no alcanza o exige ENCRYPT_PASSWORD con jConnect)
# Requiere Node 18 LTS si usas: npm install jdbc
SYBASE_JDBC_URL=jdbc:sybase:Tds:HOST:4901?ENCRYPT_PASSWORD=true
SYBASE_JDBC_CLASS_NAME=com.sybase.jdbc4.jdbc.SybDriver
SYBASE_JDBC_DRIVER_PATH=/opt/sap/jdbc/jconn4.jar
JVM_PATH=/usr/lib/jvm/java-17-openjdk-amd64/lib/server

DB_CLIENT=mssql
DB_HOST=localhost
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_NAME=sap_sync
DB_SSL=false
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MIN=2
DB_POOL_MAX=10

DATABASE_URL="sqlserver://localhost:1433;database=sap_sync;user=YOUR_DB_USER;password=YOUR_DB_PASSWORD;encrypt=false;trustServerCertificate=true"
