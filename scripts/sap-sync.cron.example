# =============================================================================
# Crontab: sync SAP → SQL Server (misma lógica que npm run start)
# ERDAT desde: SYNC_FECHA_INICIO en .env (variable global; cada corrida hasta hoy UTC).
# =============================================================================
#
#   chmod +x /ruta/al/repo/scripts/sap-sync-cron.sh
#   crontab -e
#
# Sustituye RUTA_REPO y TU_USUARIO por valores reales.

SHELL=/bin/bash
HOME=/home/TU_USUARIO
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
CRON_TZ=America/Caracas

# Ejemplo: una vez al día 10:35 a.m. (hora Caracas si CRON_TZ=America/Caracas)
35 10 * * * /ruta/al/repo/scripts/sap-sync-cron.sh >> /ruta/al/repo/logs/cron-sync.log 2>&1
