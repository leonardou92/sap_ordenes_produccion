generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model SyncLog {
  id             BigInt    @id @default(autoincrement())
  source         String    @default("SAP")
  targetTable    String
  batchSize      Int
  totalProcessed Int
  status         String
  errorMessage   String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  @@map("sync_logs")
}

/// Líneas de OP (AFPO) × estatus activos (JEST/TJ02T). PK incluye STAT por posibles múltiples estatus por orden.
/// Índices orientados a lectura por orden/fecha/estatus en volúmenes grandes.
model SapOrdenProduccionLine {
  sapLineId                  String    @id @map("sap_line_id") @db.VarChar(132)
  orden                      String    @map("orden") @db.VarChar(24)
  posicion                   String    @map("posicion") @db.VarChar(12)
  statSistema                String    @map("stat_sistema") @db.VarChar(16)
  codProductoPrincipal       String?   @map("cod_producto_principal") @db.VarChar(40)
  descProductoPrincipal      String?   @map("desc_producto_principal") @db.VarChar(120)
  codMaterialDetalle         String?   @map("cod_material_detalle") @db.VarChar(40)
  descripcionMaterialDetalle String?   @map("descripcion_material_detalle") @db.VarChar(120)
  estatusBreve               String?   @map("estatus_breve") @db.VarChar(64)
  estatusDetallado           String?   @map("estatus_detallado") @db.VarChar(200)
  fechaCreacion              DateTime? @map("fecha_creacion") @db.Date
  fechaInicioPlan            DateTime? @map("fecha_inicio_plan") @db.Date
  fechaFinPlan               DateTime? @map("fecha_fin_plan") @db.Date
  fechaInicioReal            DateTime? @map("fecha_inicio_real") @db.Date
  fechaFinReal               DateTime? @map("fecha_fin_real") @db.Date
  cantPlaneada               Decimal?  @map("cant_planeada") @db.Decimal(18, 6)
  cantProducidaReal          Decimal?  @map("cant_producida_real") @db.Decimal(18, 6)
  unidadMedida               String?   @map("unidad_medida") @db.VarChar(12)
  tipoOrden                  String?   @map("tipo_orden") @db.VarChar(80)
  syncedAt                   DateTime  @default(now()) @map("synced_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  @@index([orden, posicion], map: "ix_sap_ord_line_orden_pos")
  @@index([fechaCreacion], map: "ix_sap_ord_line_fecha_creacion")
  @@index([statSistema], map: "ix_sap_ord_line_stat")
  @@index([estatusBreve], map: "ix_sap_ord_line_estatus_breve")
  @@map("ordenes_produccion")
}
