generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model SyncLog {
  id             BigInt    @id @default(autoincrement())
  source         String    @default("SAP")
  targetTable    String
  batchSize      Int
  totalProcessed Int
  status         String
  errorMessage   String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  @@map("sync_logs")
}

/// Líneas de OP (AFPO) × estatus activos (JEST/TJ02T). PK incluye STAT por posibles múltiples estatus por orden.
/// Índices orientados a lectura por orden/fecha/estatus en volúmenes grandes.
model SapOrdenProduccionLine {
  sapLineId                  String    @id @map("sap_line_id") @db.VarChar(132)
  orden                      String    @map("orden") @db.VarChar(24)
  posicion                   String    @map("posicion") @db.VarChar(12)
  statSistema                String    @map("stat_sistema") @db.VarChar(16)
  codProductoPrincipal       String?   @map("cod_producto_principal") @db.VarChar(40)
  descProductoPrincipal      String?   @map("desc_producto_principal") @db.VarChar(120)
  codMaterialDetalle         String?   @map("cod_material_detalle") @db.VarChar(40)
  descripcionMaterialDetalle String?   @map("descripcion_material_detalle") @db.VarChar(120)
  estatusBreve               String?   @map("estatus_breve") @db.VarChar(64)
  estatusDetallado           String?   @map("estatus_detallado") @db.VarChar(200)
  fechaCreacion              DateTime? @map("fecha_creacion") @db.Date
  fechaInicioPlan            DateTime? @map("fecha_inicio_plan") @db.Date
  fechaFinPlan               DateTime? @map("fecha_fin_plan") @db.Date
  fechaInicioReal            DateTime? @map("fecha_inicio_real") @db.Date
  fechaFinReal               DateTime? @map("fecha_fin_real") @db.Date
  cantPlaneada               Decimal?  @map("cant_planeada") @db.Decimal(18, 6)
  cantProducidaReal          Decimal?  @map("cant_producida_real") @db.Decimal(18, 6)
  unidadMedida               String?   @map("unidad_medida") @db.VarChar(12)
  tipoOrden                  String?   @map("tipo_orden") @db.VarChar(80)
  syncedAt                   DateTime  @default(now()) @map("synced_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  @@index([orden, posicion], map: "ix_sap_ord_line_orden_pos")
  @@index([fechaCreacion], map: "ix_sap_ord_line_fecha_creacion")
  @@index([statSistema], map: "ix_sap_ord_line_stat")
  @@index([estatusBreve], map: "ix_sap_ord_line_estatus_breve")
  @@map("ordenes_produccion")
}

model FactProduccion {
  factProduccionId String    @id @map("fact_produccion_id") @db.VarChar(140)
  ordenId          String    @map("orden_id") @db.VarChar(24)
  centroId         String?   @map("centro_id") @db.VarChar(12)
  productoDesc     String?   @map("producto_desc") @db.VarChar(200)
  fechaCreacion    DateTime? @map("fecha_creacion") @db.Date
  fechaInicioPlan  DateTime? @map("fecha_inicio_plan") @db.Date
  fechaFinPlan     DateTime? @map("fecha_fin_plan") @db.Date
  fechaFinReal     DateTime? @map("fecha_fin_real") @db.Date
  cantPlanificada  Decimal?  @map("cant_planificada") @db.Decimal(18, 3)
  cantReal         Decimal?  @map("cant_real") @db.Decimal(18, 3)
  unidadMedida     String?   @map("unidad_medida") @db.VarChar(12)
  syncedAt         DateTime  @default(now()) @map("synced_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([ordenId], map: "ix_fact_produccion_orden_id")
  @@index([fechaFinReal], map: "ix_fact_produccion_fecha_fin_real")
  @@index([centroId], map: "ix_fact_produccion_centro_id")
  @@map("fact_produccion")
}

model FactConsumos {
  factConsumoId      String    @id @map("fact_consumo_id") @db.VarChar(180)
  ordenId            String    @map("orden_id") @db.VarChar(24)
  componenteDesc     String?   @map("componente_desc") @db.VarChar(200)
  cantNecesaria      Decimal?  @map("cant_necesaria") @db.Decimal(18, 3)
  cantConsumidaReal  Decimal?  @map("cant_consumida_real") @db.Decimal(18, 3)
  unidadMedida       String?   @map("unidad_medida") @db.VarChar(12)
  desviacionMaterial Decimal?  @map("desviacion_material") @db.Decimal(18, 3)
  syncedAt           DateTime  @default(now()) @map("synced_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([ordenId], map: "ix_fact_consumos_orden_id")
  @@index([desviacionMaterial], map: "ix_fact_consumos_desviacion")
  @@map("fact_consumos")
}

model DimOrdenes {
  ordenId         String   @id @map("orden_id") @db.VarChar(24)
  tipoOrdenDesc   String?  @map("tipo_orden_desc") @db.VarChar(120)
  centroDesc      String?  @map("centro_desc") @db.VarChar(120)
  estatusActual   String?  @map("estatus_actual") @db.VarChar(120)
  syncedAt        DateTime @default(now()) @map("synced_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([estatusActual], map: "ix_dim_ordenes_estatus_actual")
  @@index([centroDesc], map: "ix_dim_ordenes_centro_desc")
  @@map("dim_ordenes")
}

/// Catálogo de plantas SAP (T001W) filtradas por WERKS LIKE 'PB%'.
model DimPlantas {
  codigoPlanta      String   @id @map("codigo_planta") @db.VarChar(12)
  nombrePlanta      String?  @map("nombre_planta") @db.VarChar(120)
  sociedadCodigo    String?  @map("sociedad_codigo") @db.VarChar(12)
  centroValoracion  String?  @map("centro_valoracion") @db.VarChar(12)
  ciudad            String?  @map("ciudad") @db.VarChar(80)
  pais              String?  @map("pais") @db.VarChar(6)
  syncedAt          DateTime @default(now()) @map("synced_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([nombrePlanta], map: "ix_dim_plantas_nombre")
  @@index([sociedadCodigo], map: "ix_dim_plantas_sociedad")
  @@map("dim_plantas")
}

/// Reporte central: aves estimadas y mermas por planta y día (GSTRI).
model FactProduccionResumen {
  fecha             DateTime @map("fecha") @db.Date
  codigoPlanta      String   @map("codigo_planta") @db.VarChar(12)
  nombrePlanta      String?  @map("nombre_planta") @db.VarChar(120)
  avesProcesadas    Decimal? @map("aves_procesadas") @db.Decimal(18, 0)
  kgPlantaTotal     Decimal? @map("kg_planta_total") @db.Decimal(18, 2)
  kgGranjaTotal     Decimal? @map("kg_granja_total") @db.Decimal(18, 2)
  difKg             Decimal? @map("dif_kg") @db.Decimal(18, 2)
  porcentajeMerma   Decimal? @map("porcentaje_merma") @db.Decimal(18, 2)
  syncedAt          DateTime @default(now()) @map("synced_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@id([fecha, codigoPlanta])
  @@map("fact_produccion_resumen")
}

/// Recepción por camión / lote (AFPO pos. 0001).
model FactRecepcionCamiones {
  fecha               DateTime @map("fecha") @db.Date
  codigoPlanta        String   @map("codigo_planta") @db.VarChar(12)
  placaLote           String   @map("placa_lote") @db.VarChar(40)
  granjaDescripcion   String?  @map("granja_descripcion") @db.VarChar(200)
  kgGranja            Decimal? @map("kg_granja") @db.Decimal(18, 2)
  kgPlanta            Decimal? @map("kg_planta") @db.Decimal(18, 2)
  avesRecibidas       Decimal? @map("aves_recibidas") @db.Decimal(18, 0)
  difKg               Decimal? @map("dif_kg") @db.Decimal(18, 2)
  syncedAt            DateTime @default(now()) @map("synced_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@id([fecha, codigoPlanta, placaLote])
  @@map("fact_recepcion_camiones")
}

/// Despiece por producto (KG).
model FactProduccionDetalleReporte {
  fecha           DateTime @map("fecha") @db.Date
  codigoPlanta    String   @map("codigo_planta") @db.VarChar(12)
  codigoProducto  String   @map("codigo_producto") @db.VarChar(40)
  referencia      String?  @map("referencia") @db.VarChar(200)
  kgProducidos    Decimal? @map("kg_producidos") @db.Decimal(18, 2)
  syncedAt        DateTime @default(now()) @map("synced_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@id([fecha, codigoPlanta, codigoProducto])
  @@map("fact_produccion_detalle_reporte")
}

/// Consumo de materiales de empaque (RESB filtrado).
model FactMaterialesEmpaque {
  fecha                 DateTime @map("fecha") @db.Date
  codigoPlanta          String   @map("codigo_planta") @db.VarChar(12)
  codigoMaterial        String   @map("codigo_material") @db.VarChar(40)
  descripcionMaterial   String?  @map("descripcion_material") @db.VarChar(200)
  cantidadConsumida     Decimal? @map("cantidad_consumida") @db.Decimal(18, 0)
  unidad                String   @map("unidad") @db.VarChar(12)
  syncedAt              DateTime @default(now()) @map("synced_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@id([fecha, codigoPlanta, codigoMaterial, unidad])
  @@map("fact_materiales_empaque")
}
