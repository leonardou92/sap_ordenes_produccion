{
  "name": "sap-sql-sync",
  "version": "1.0.0",
  "description": "Sincronizador robusto y eficiente de datos SAP hacia SQL con Node.js + TypeScript + Knex",
  "main": "dist/sync.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/sync.js",
    "dev": "ts-node src/sync.ts",
    "start:api": "node dist/server.js",
    "dev:api": "ts-node src/server.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "keywords": [
    "sap",
    "sync",
    "knex",
    "typescript",
    "sql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jdbc": "^0.7.6",
    "knex": "^3.1.0",
    "odbc": "^2.4.9",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "nodemon": "^3.1.14",
    "prisma": "^6.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
