{
  "name": "sap-ordenes-produccion",
  "version": "1.0.0",
  "description": "Backend TypeScript: órdenes de producción SAP (Sybase ASE) → SQL Server, API Express y sync programable.",
  "main": "dist/sync.js",
  "scripts": {
    "postinstall": "npx patch-package",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/sync.js",
    "dev": "ts-node src/sync.ts",
    "start:fact-produccion-resumen": "node dist/sync-fact-produccion-resumen.js",
    "dev:fact-produccion-resumen": "ts-node src/sync-fact-produccion-resumen.ts",
    "start:fact-recepcion-camiones": "node dist/sync-fact-recepcion-camiones.js",
    "dev:fact-recepcion-camiones": "ts-node src/sync-fact-recepcion-camiones.ts",
    "start:fact-produccion-detalle-reporte": "node dist/sync-fact-produccion-detalle-reporte.js",
    "dev:fact-produccion-detalle-reporte": "ts-node src/sync-fact-produccion-detalle-reporte.ts",
    "start:fact-materiales-empaque": "node dist/sync-fact-materiales-empaque.js",
    "dev:fact-materiales-empaque": "ts-node src/sync-fact-materiales-empaque.ts",
    "start:dim-plantas": "node dist/sync-dim-plantas.js",
    "dev:dim-plantas": "ts-node src/sync-dim-plantas.ts",
    "start:api": "node dist/server.js",
    "dev:api": "ts-node src/server.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:sql:apply": "prisma db execute --file prisma/migrations/20260408140000_init_sap_ordenes_tables/migration.sql --schema prisma/schema.prisma && prisma db execute --file prisma/migrations/20260408160000_rename_to_ordenes_produccion/migration.sql --schema prisma/schema.prisma && prisma db execute --file prisma/migrations/20260417120000_add_fact_reporte_diario_pb/migration.sql --schema prisma/schema.prisma && prisma db execute --file prisma/migrations/20260420103000_add_dim_plantas/migration.sql --schema prisma/schema.prisma",
    "prisma:baseline:init": "prisma migrate resolve --applied 20260408140000_init_sap_ordenes_tables"
  },
  "keywords": [
    "sap",
    "sync",
    "knex",
    "typescript",
    "sql"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18 <22"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jdbc": "^0.7.6",
    "knex": "^3.1.0",
    "mssql": "^12.2.1",
    "odbc": "^2.4.9",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/helmet": "^0.0.48",
    "@types/node": "^22.7.4",
    "patch-package": "^8.0.1",
    "prisma": "^6.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
