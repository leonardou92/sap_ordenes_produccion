# Añadir al final de /etc/freetds/freetds.conf (sudo nano /etc/freetds/freetds.conf).
# El nombre [sap_ase_odbc] debe coincidir con Servername en /etc/odbc.ini
#
# Valores válidos: off | request | require (no uses "required").
# Si falla, prueba: encryption = request

[global]
	tds version = 5.0

[sap_ase_odbc]
	host = 10.1.6.234
	port = 4901
	tds version = 5.0
	encryption = require
